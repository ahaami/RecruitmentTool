# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Apollo.io (Phase 2)
APOLLO_API_KEY=your-apollo-key

# Lusha (contact enrichment — phone + email)
LUSHA_API_KEY=your-lusha-api-key

# Resend (Phase 3)
RESEND_API_KEY=re_...
CALLSHEET_TO_EMAIL=alex@example.com
CALLSHEET_FROM_EMAIL=recruiter-tool@yourdomain.com

# Configuration
DAILY_CALL_LIMIT=20
COOLDOWN_DAYS=14
MIN_GROWTH_SCORE=40
TARGET_CITIES=Sydney,Melbourne,Brisbane,Perth,Canberra
